{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug with Args",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/graph_search",
            "args": [
                "-g",
                "/home/share/chenh/hyb/dataset/output1.txt",
                "-q",
                "/home/chenh/hyb/project/version37/block_based_temporal_subgraph/motifs/M1.txt",
                "-o",
                "${workspaceFolder}/out1.gdf",
                "-delta",
                "24h"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "preLaunchTask": "Build GraphSearch Project",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}